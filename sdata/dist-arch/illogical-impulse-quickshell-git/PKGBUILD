# Now uses the official repo `quickshell` instead of building a pinned git commit.
# Kept the package name to avoid touching install-deps routing; it is a meta
# package now (no build), pulling repo quickshell + the extra Qt deps ii needs.

groups=(illogical-impulse)
pkgname=illogical-impulse-quickshell-git
pkgver=1.0
pkgrel=1
pkgdesc='Official Quickshell + extra Qt deps for illogical-impulse'
arch=(any)
license=(None)
depends=(
  quickshell
  # Extra deps used by the ii config (repo quickshell pulls its own core deps).
  qt6-5compat
  qt6-avif-image-plugin
  qt6-imageformats
  qt6-multimedia
  qt6-positioning
  qt6-quicktimeline
  qt6-sensors
  qt6-svg
  qt6-tools
  qt6-translations
  qt6-virtualkeyboard
  qt6-wayland
  kirigami
  kdialog
  syntax-highlighting
)
